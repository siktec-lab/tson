{
  "name": "tson",
  "version": "0.1.0",
  "description": "Terse JSON — compact binary JSON for microcontrollers",
  "keywords": ["json", "binary", "serialization", "embedded", "iot", "napi-rs"],
  "license": "MIT",
  "author": "SIKTEC Lab <siktec.lab@gmail.com>",
  "homepage": "https://github.com/siktec-lab/tson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siktec-lab/tson.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/siktec-lab/tson/issues"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": ["index.js", "index.d.ts"],
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "binaryName": "tson",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --manifest-path ../Cargo.toml -F nodejs -o .",
    "build:debug": "napi build --platform --manifest-path ../Cargo.toml -F nodejs -o .",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "test": "node test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  },
  "optionalDependencies": {
    "tson-linux-x64-gnu": "0.1.0",
    "tson-linux-arm64-gnu": "0.1.0",
    "tson-darwin-x64": "0.1.0",
    "tson-darwin-arm64": "0.1.0",
    "tson-win32-x64-msvc": "0.1.0"
  }
}
